<%- include('partials/navbar') %>

<body>
    <%- include('partials/admin_sidebar') %>
    
    <div class="main-content">
        <%- include('partials/admin_header') %>
        
        <div class="container-fluid p-4">
            <!-- Search and Filter Bar -->
            <div class="search-filter-bar">
                <div class="row align-items-center">
                    <div class="col-md-4">
                        <div class="input-group">
                            <input type="text" class="form-control" id="searchInput" placeholder="Buscar por livro ou usuário...">
                            <button class="btn btn-outline-secondary" type="button" id="searchBtn">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" id="statusFilter">
                            <option value="">Todos os status</option>
                            <option value="active">Ativo</option>
                            <option value="returned">Devolvido</option>
                            <option value="overdue">Atrasado</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input type="date" class="form-control" id="dateFilter" title="Filtrar por data">
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-primary w-100" data-bs-toggle="modal" data-bs-target="#lendingModal">
                            <i class="fas fa-plus me-2"></i>Novo Empréstimo
                        </button>
                    </div>
                </div>
            </div>
            
            <!-- Lending Table -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Gerenciar Empréstimos</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Livro</th>
                                    <th>Usuário</th>
                                    <th>Data Empréstimo</th>
                                    <th>Data Devolução</th>
                                    <th>Status</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody id="lendingTableBody">
                                <tr>
                                    <td colspan="6" class="text-center">
                                        <div class="spinner-border" role="status">
                                            <span class="visually-hidden">Carregando...</span>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    
                    <!-- Pagination -->
                    <nav aria-label="Paginação de empréstimos">
                        <ul class="pagination justify-content-center" id="pagination">
                            <!-- Pagination will be generated by JavaScript -->
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>

    <!-- Lending Modal -->
    <div class="modal fade" id="lendingModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="lendingModalTitle">Novo Empréstimo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="lendingForm">
                    <div class="modal-body">
                        <input type="hidden" id="lendingId" name="lendingId">
                        
                        <div class="mb-3">
                            <label for="bookSelect" class="form-label">Livro</label>
                            <select class="form-select" id="bookSelect" name="book" required>
                                <option value="">Carregando livros...</option>
                            </select>
                        </div>
                        
                        <div class="mb-3">
                            <label for="userSelect" class="form-label">Usuário</label>
                            <select class="form-select" id="userSelect" name="user" required>
                                <option value="">Carregando usuários...</option>
                            </select>
                        </div>
                        
                        <div class="mb-3">
                            <label for="startDate" class="form-label">Data de Empréstimo</label>
                            <input type="date" class="form-control" id="startDate" name="startDate" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="endDate" class="form-label">Data de Devolução</label>
                            <input type="date" class="form-control" id="endDate" name="endDate" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary" id="saveLendingBtn">
                            <span class="spinner-border spinner-border-sm d-none me-2"></span>
                            Salvar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Extend Modal -->
    <div class="modal fade" id="extendModal" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Estender Prazo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="extendForm">
                    <div class="modal-body">
                        <input type="hidden" id="extendLendingId">
                        <div class="mb-3">
                            <label for="newEndDate" class="form-label">Nova Data de Devolução</label>
                            <input type="date" class="form-control" id="newEndDate" name="newEndDate" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-warning">Estender</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Custom Toast Container -->
    <div id="toast-container"></div>

    <script>
        let currentPage = 1;
        let currentLimit = 10;
        let currentSearch = '';
        let currentStatus = '';
        let currentDate = '';
        let isEditing = false;

        // Initialize page
        document.addEventListener('DOMContentLoaded', function() {
            loadLending();
            setupEventListeners();
            setDefaultDates();
        });

        function setupEventListeners() {
            // Search functionality
            document.getElementById('searchBtn').addEventListener('click', performSearch);
            document.getElementById('searchInput').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') performSearch();
            });
            
            // Filters
            document.getElementById('statusFilter').addEventListener('change', performSearch);
            document.getElementById('dateFilter').addEventListener('change', performSearch);
            
            // Form submissions
            document.getElementById('lendingForm').addEventListener('submit', handleFormSubmit);
            document.getElementById('extendForm').addEventListener('submit', handleExtendSubmit);
            
            // Modal events
            document.getElementById('lendingModal').addEventListener('show.bs.modal', loadModalData);
            document.getElementById('lendingModal').addEventListener('hidden.bs.modal', resetForm);
            
            // Sidebar toggle for mobile
            const sidebarToggle = document.getElementById('sidebarToggle');
            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', function() {
                    document.querySelector('.sidebar').classList.toggle('show');
                });
            }
        }

        function setDefaultDates() {
            const today = new Date().toISOString().split('T')[0];
            const nextWeek = new Date(Date.now() + 14 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
            
            document.getElementById('startDate').value = today;
            document.getElementById('endDate').value = nextWeek;
        }

        async function loadLending(page = 1) {
            try {
                currentPage = page;
                let url;
                
                if (currentSearch) {
                    url = `/api/lending/search?query=${encodeURIComponent(currentSearch)}`;
                } else {
                    url = `/api/lending/${currentPage}/${currentLimit}`;
                }
                
                const response = await fetch(url);
                const data = await response.json();
                
                let lending = data.lending || data;
                
                // Apply filters
                if (currentStatus) {
                    lending = lending.filter(item => item.status === currentStatus);
                }
                
                if (currentDate) {
                    lending = lending.filter(item => {
                        const startDate = new Date(item.startDate).toISOString().split('T')[0];
                        return startDate === currentDate;
                    });
                }
                
                displayLending(lending);
                updatePagination(data.total, data.page, data.lastPage);
                
            } catch (error) {
                console.error('Erro ao carregar empréstimos:', error);
                showToast('Erro ao carregar empréstimos', 'error');
            }
        }

        function displayLending(lending) {
            const tbody = document.getElementById('lendingTableBody');
            
            if (!lending || lending.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-center">Nenhum empréstimo encontrado</td></tr>';
                return;
            }
            
            tbody.innerHTML = lending.map(item => {
                const book = item.book || {};
                const user = item.user || {};
                const startDate = new Date(item.startDate).toLocaleDateString('pt-BR');
                const endDate = new Date(item.endDate).toLocaleDateString('pt-BR');
                const isOverdue = new Date(item.endDate) < new Date() && item.status === 'active';
                
                return `
                    <tr>
                        <td>
                            <strong>${book.title || 'Livro não encontrado'}</strong><br>
                            <small class="text-muted">${book.author || ''}</small>
                        </td>
                        <td>
                            <strong>${user.fullName || user.username || 'Usuário não encontrado'}</strong><br>
                            <small class="text-muted">${user.email || ''}</small>
                        </td>
                        <td>${startDate}</td>
                        <td>${endDate}</td>
                        <td>${getStatusBadge(item.status, isOverdue)}</td>
                        <td>
                            ${item.status === 'active' ? `
                                <button class="btn btn-sm btn-outline-success btn-action btn-return-book" data-lending-id="${item._id}" title="Marcar como devolvido">
                                    <i class="fas fa-check"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-warning btn-action btn-extend-lending" data-lending-id="${item._id}" data-end-date="${item.endDate}" title="Estender prazo">
                                    <i class="fas fa-calendar-plus"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger btn-action btn-delete-lending" data-lending-id="${item._id}" title="Remover empréstimo">
                                    <i class="fas fa-trash"></i>
                                </button>
                            ` : item.status === 'returned' ? `
                                <span class="text-muted">
                                    <i class="fas fa-check-circle"></i> Devolvido
                                </span>
                            ` : `
                                <button class="btn btn-sm btn-outline-danger btn-action btn-delete-lending" data-lending-id="${item._id}" title="Remover empréstimo">
                                    <i class="fas fa-trash"></i>
                                </button>
                            `}
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function getStatusBadge(status, isOverdue) {
            if (isOverdue) {
                return '<span class="badge bg-danger">Atrasado</span>';
            }
            
            const badges = {
                'active': '<span class="badge bg-primary">Ativo</span>',
                'returned': '<span class="badge bg-success">Devolvido</span>',
                'overdue': '<span class="badge bg-danger">Atrasado</span>'
            };
            return badges[status] || `<span class="badge bg-secondary">${status}</span>`;
        }

        function updatePagination(total, page, lastPage) {
            const pagination = document.getElementById('pagination');
            if (!total || total <= currentLimit) {
                pagination.innerHTML = '';
                return;
            }
            
            let paginationHTML = '';
            
            // Previous button
            if (page > 1) {
                paginationHTML += `<li class="page-item"><a class="page-link pagination-link" href="#" data-page="${page - 1}">Anterior</a></li>`;
            }
            
            // Page numbers
            for (let i = Math.max(1, page - 2); i <= Math.min(lastPage, page + 2); i++) {
                paginationHTML += `<li class="page-item ${i === page ? 'active' : ''}">
                    <a class="page-link pagination-link" href="#" data-page="${i}">${i}</a>
                </li>`;
            }
            
            // Next button
            if (page < lastPage) {
                paginationHTML += `<li class="page-item"><a class="page-link pagination-link" href="#" data-page="${page + 1}">Próximo</a></li>`;
            }
            
            pagination.innerHTML = paginationHTML;
        }

        function performSearch() {
            currentSearch = document.getElementById('searchInput').value.trim();
            currentStatus = document.getElementById('statusFilter').value;
            currentDate = document.getElementById('dateFilter').value;
            currentPage = 1;
            loadLending();
        }

        async function loadModalData() {
            try {
                // Load available books
                const booksResponse = await fetch('/api/books');
                const booksData = await booksResponse.json();
                
                // Verificar se a resposta tem o formato correto
                const books = booksData.success ? booksData.books : (Array.isArray(booksData) ? booksData : []);
                const availableBooks = books.filter(book => book.quantity > 0);
                
                const bookSelect = document.getElementById('bookSelect');
                bookSelect.innerHTML = '<option value="">Selecione um livro</option>' +
                    availableBooks.map(book => `<option value="${book._id}">${book.title} - ${book.author}</option>`).join('');
                
                // Load users
                const usersResponse = await fetch('/api/users/1/100');
                const usersData = await usersResponse.json();
                const users = usersData.users || usersData;
                
                const userSelect = document.getElementById('userSelect');
                userSelect.innerHTML = '<option value="">Selecione um usuário</option>' +
                    users.map(user => `<option value="${user._id}">${user.fullName || user.username} (${user.email})</option>`).join('');
                
            } catch (error) {
                console.error('Erro ao carregar dados do modal:', error);
                showToast('Erro ao carregar dados', 'error');
            }
        }

        async function handleFormSubmit(e) {
            e.preventDefault();
            
            const saveBtn = document.getElementById('saveLendingBtn');
            const spinner = saveBtn.querySelector('.spinner-border');
            
            saveBtn.disabled = true;
            spinner.classList.remove('d-none');
            
            try {
                const formData = new FormData(e.target);
                const lendingData = Object.fromEntries(formData.entries());
                
                const response = await fetch('/api/lending/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(lendingData)
                });
                
                if (response.ok) {
                    showToast('Empréstimo criado com sucesso!', 'success');
                    bootstrap.Modal.getInstance(document.getElementById('lendingModal')).hide();
                    loadLending(currentPage);
                } else {
                    const error = await response.json();
                    showToast(error.message || 'Erro ao criar empréstimo', 'error');
                }
                
            } catch (error) {
                console.error('Erro ao salvar empréstimo:', error);
                showToast('Erro ao salvar empréstimo', 'error');
            } finally {
                saveBtn.disabled = false;
                spinner.classList.add('d-none');
            }
        }

        async function returnBook(lendingId) {
            if (!confirm('Confirmar devolução do livro?')) return;
            
            try {
                const response = await fetch(`/api/lending/remove/${lendingId}`, {
                    method: 'POST'
                });
                
                if (response.ok) {
                    showToast('Livro devolvido com sucesso!', 'success');
                    loadLending(currentPage);
                } else {
                    showToast('Erro ao processar devolução', 'error');
                }
                
            } catch (error) {
                console.error('Erro ao devolver livro:', error);
                showToast('Erro ao devolver livro', 'error');
            }
        }

        function extendLending(lendingId, currentEndDate) {
            console.log('Extending lending:', lendingId, currentEndDate); // Debug
            document.getElementById('extendLendingId').value = lendingId;
            
            // Verificar se a data é válida
            let dateValue = '';
            if (currentEndDate) {
                const date = new Date(currentEndDate);
                if (!isNaN(date.getTime())) {
                    dateValue = date.toISOString().split('T')[0];
                } else {
                    // Se a data atual for inválida, usar data de hoje + 7 dias
                    const futureDate = new Date();
                    futureDate.setDate(futureDate.getDate() + 7);
                    dateValue = futureDate.toISOString().split('T')[0];
                }
            }
            
            document.getElementById('newEndDate').value = dateValue;
            new bootstrap.Modal(document.getElementById('extendModal')).show();
        }

        async function handleExtendSubmit(e) {
            e.preventDefault();
            
            try {
                const lendingId = document.getElementById('extendLendingId').value;
                const newEndDate = document.getElementById('newEndDate').value;
                
                const response = await fetch(`/api/lending/extend/${lendingId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ newEndDate })
                });
                
                if (response.ok) {
                    showToast('Prazo estendido com sucesso!', 'success');
                    bootstrap.Modal.getInstance(document.getElementById('extendModal')).hide();
                    loadLending(currentPage);
                } else {
                    showToast('Erro ao estender prazo', 'error');
                }
                
            } catch (error) {
                console.error('Erro ao estender prazo:', error);
                showToast('Erro ao estender prazo', 'error');
            }
        }

        async function deleteLending(lendingId) {
            if (!confirm('Tem certeza que deseja remover este empréstimo? Esta ação não pode ser desfeita.')) return;
            
            try {
                const response = await fetch(`/api/lending/delete/${lendingId}`, {
                    method: 'POST'
                });
                
                if (response.ok) {
                    showToast('Empréstimo removido com sucesso!', 'success');
                    loadLending(currentPage);
                } else {
                    showToast('Erro ao remover empréstimo', 'error');
                }
                
            } catch (error) {
                console.error('Erro ao remover empréstimo:', error);
                showToast('Erro ao remover empréstimo', 'error');
            }
        }

        function resetForm() {
            document.getElementById('lendingForm').reset();
            document.getElementById('lendingId').value = '';
            setDefaultDates();
        }

        // Event Delegation for action buttons
        document.addEventListener('click', function(e) {
            if (e.target.closest('.btn-return-book')) {
                const lendingId = e.target.closest('.btn-return-book').dataset.lendingId;
                returnBook(lendingId);
            } else if (e.target.closest('.btn-extend-lending')) {
                const button = e.target.closest('.btn-extend-lending');
                const lendingId = button.dataset.lendingId;
                const endDate = button.dataset.endDate;
                extendLending(lendingId, endDate);
            } else if (e.target.closest('.btn-delete-lending')) {
                const lendingId = e.target.closest('.btn-delete-lending').dataset.lendingId;
                deleteLending(lendingId);
            } else if (e.target.closest('.pagination-link')) {
                e.preventDefault();
                const page = parseInt(e.target.closest('.pagination-link').dataset.page);
                loadLending(page);
            }
        });
    </script>

<%- include('partials/footer') %>
